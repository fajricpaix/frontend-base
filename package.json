{
  "name": "@fajricpaix/frontend-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "UI Component Library for React/Next.js projects",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "rollup -c && npx tsc --project tsconfig.lib.json --declaration --emitDeclarationOnly",
    "build:next": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "nextjs",
    "typescript",
    "tailwindcss"
  ],
  "author": "fajricpaix",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fajricpaix/frontend-base.git"
  },
  "dependencies": {
    "next": "15.5.5",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.5",
    "postcss": "^8.5.6",
    "rollup": "^4.0.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.0",
    "tailwindcss": "^4",
    "tslib": "^2.6.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
